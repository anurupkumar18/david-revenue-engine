# Copy to backend/.env and fill in values, then restart uvicorn.
# Demo mode works with NO vars set (simulated sends, auto demo user).

# --- Required for live OAuth sending ---
AUTH_SECRET=change-me-to-a-long-random-string
PUBLIC_BASE_URL=http://localhost:3000

# Optional: dedicated Fernet key; if unset, derived from AUTH_SECRET in dev
# TOKEN_ENCRYPTION_KEY=

# Google OAuth (Gmail send)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (optional)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# Auto-drain send queue (start.sh sets this to 1)
SCHEDULER_ENABLED=1

# CAN-SPAM footer
# COMPANY_POSTAL_ADDRESS=123 Main St, City, ST 00000

# Optional Resend fallback (not needed when using OAuth mailbox)
# RESEND_API_KEY=
