# David Revenue Engine — environment
# Everything works deterministically with NO keys set.
# Add a key only to enable the optional LLM enhancement layer.

# Optional: enables LLM-authored Fitting Strategy, Conversion Outreach, and reply routing.
# When absent, the app falls back to deterministic templates and the demo still runs end-to-end.
ANTHROPIC_API_KEY=

# Optional model override (defaults to a sensible Claude model in lib/llm.ts)
# ANTHROPIC_MODEL=claude-sonnet-4-6

NEXT_PUBLIC_APP_URL=http://localhost:3000
